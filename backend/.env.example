# ── Base de datos ─────────────────────────────────────────────
DATABASE_URL=postgresql://usuario:password@localhost:5432/contratistas_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=contratistas_db
DB_USER=usuario
DB_PASSWORD=password
DB_SSL=false

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=cambia_este_secreto_muy_largo_en_produccion_2025
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# ── Servidor ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── AWS S3 (almacenamiento documentos) ───────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=tu_access_key
AWS_SECRET_ACCESS_KEY=tu_secret_key
AWS_S3_BUCKET=contratistas-documentos

# ── Firebase (notificaciones push) ───────────────────────────
FIREBASE_PROJECT_ID=tu_proyecto_firebase
FIREBASE_PRIVATE_KEY=tu_private_key
FIREBASE_CLIENT_EMAIL=tu_client_email

# ── SendGrid (correos) ────────────────────────────────────────
SENDGRID_API_KEY=SG.tu_api_key
EMAIL_FROM=noreply@entidad.gov.co
EMAIL_FROM_NAME=Sistema Contratistas

# ── SECOP II ──────────────────────────────────────────────────
SECOP_API_URL=https://www.colombiacompra.gov.co/api/v1
SECOP_API_KEY=tu_api_key_secop

{
  "expo": {
    "name": "ContralControl",
    "slug": "contractorco",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#0d1f3c"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "co.contractorco.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0d1f3c"
      },
      "package": "co.contractorco.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-notifications",
      "expo-font"
    ]
  }
}
